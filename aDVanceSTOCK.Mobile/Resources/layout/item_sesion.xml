<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:layout_marginBottom="4dp">

    <!-- Badge tipo -->
    <TextView
        android:id="@+id/lblBadgeTipo"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:gravity="center"
        android:text="NUEVO"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.12" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Ícono imagen -->
        <ImageView
            android:id="@+id/icnFoto"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginRight="8dp"
            android:src="@drawable/ic_catalog"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/lblItemCodigo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/lblItemNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del producto"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/lblItemCantidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cantidad: 0"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/lblItemPrecio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#B22222"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Eliminar -->
        <ImageButton
            android:id="@+id/btnEliminarItem"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:tint="#CCCCCC" />
    </LinearLayout>
</LinearLayout>
