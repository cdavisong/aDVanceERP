<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — LANDSCAPE / TABLET
    Recursos: layout-land/

    Estructura:
    ┌─────────────────────────────────────────────┐
    │              TOOLBAR                        │
    ├───────────────────┬─────────────────────────┤
    │   BUSCADOR        │                         │
    │   ─────────────   │      CARRITO            │
    │   LISTA           │      ─────────────      │
    │   PRODUCTOS       │      TOTAL + COBRAR     │
    └───────────────────┴─────────────────────────┘
    
    Todos los @+id son idénticos al layout portrait
    para que MainActivity los encuentre sin cambios en código.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ══ TOOLBAR ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:elevation="4dp">

        <!-- Marca -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="aDVance"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#222222" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POS"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#B22222"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginLeft="6dp" />
        </LinearLayout>

        <!-- Badge ventas -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginRight="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VENTAS"
                android:textSize="8sp"
                android:textColor="#AAAAAA"
                android:layout_marginRight="4dp" />

            <TextView
                android:id="@+id/lblVentasBadge"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#B22222"
                android:gravity="center"
                android:background="@drawable/circle_outline"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Badge esperas -->
        <LinearLayout
            android:id="@+id/esperaContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginRight="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESPERA"
                android:textSize="8sp"
                android:textColor="#AAAAAA"
                android:layout_marginRight="4dp" />

            <TextView
                android:id="@+id/lblEsperasBadge"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#E65100"
                android:gravity="center"
                android:background="@drawable/circle_outline"
                android:clickable="true"
                android:focusable="true"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Botón configuración -->
        <ImageButton
            android:id="@+id/btnConfiguracion"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:contentDescription="Configuración" />
    </LinearLayout>

    <!-- ══ BARRA DE BÚSQUEDA (ancho completo, encima de las columnas) ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_marginTop="1dp"
        android:elevation="2dp">

        <!-- Campo de búsqueda -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/search_field_bg"
            android:paddingLeft="12dp"
            android:paddingRight="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="15sp"
                android:layout_marginRight="6dp" />

            <EditText
                android:id="@+id/txtBuscar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Buscar producto, código..."
                android:textSize="14sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <Button
                android:id="@+id/btnLimpiarBusqueda"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="✕"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Escáner -->
        <ImageButton
            android:id="@+id/btnEscanear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_scan"
            android:background="@drawable/btn_outline_firebrick"
            android:scaleType="fitCenter"
            android:padding="9dp"
            android:layout_marginLeft="8dp"
            android:contentDescription="Escáner" />

        <!-- Importar catálogo -->
        <LinearLayout
            android:id="@+id/btnImportar"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/btn_outline_firebrick"
            android:paddingLeft="10dp"
            android:paddingRight="12dp"
            android:layout_marginLeft="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_catalog"
                android:scaleType="fitCenter"
                android:layout_marginRight="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catálogo"
                android:textSize="13sp"
                android:textColor="#B22222"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══ CONTENIDO PRINCIPAL: dos columnas ══════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- ─── COLUMNA IZQUIERDA: PRODUCTOS (55% del ancho) ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="55"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:layout_marginRight="6dp"
            android:elevation="2dp">

            <!-- Cabecera productos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="#FAFAFA">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PRODUCTOS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#999999"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/lblConteoProductos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 resultados"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <ListView
                android:id="@+id/lstProductos"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#F0F0F0"
                android:dividerHeight="1dp"
                android:scrollbars="vertical" />

            <TextView
                android:id="@+id/lblProductosVacio"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="Sin productos. Usa '＋ Catálogo' para importar."
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ─── COLUMNA DERECHA: CARRITO + COBRO (45% del ancho) ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="45"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <!-- Cabecera carrito -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="#FAFAFA">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_cart"
                    android:scaleType="fitCenter"
                    android:layout_marginRight="6dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CARRITO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#999999"
                    android:letterSpacing="0.1" />

                <Button
                    android:id="@+id/btnVaciarCarrito"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Vaciar"
                    android:textSize="11sp"
                    android:textColor="#B22222"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Lista carrito -->
            <ListView
                android:id="@+id/lstCarrito"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#F0F0F0"
                android:dividerHeight="1dp" />

            <TextView
                android:id="@+id/lblCarritoVacio"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="El carrito está vacío"
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:visibility="gone" />

            <!-- Divisor total -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <!-- Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOTAL"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#999999"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/lblTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <!-- Sección cobrar -->
            <LinearLayout
                android:id="@+id/seccionPagos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:id="@+id/btnCobrar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/btn_firebrick">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_pay"
                            android:scaleType="fitCenter"
                            android:layout_marginRight="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cobrar"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
