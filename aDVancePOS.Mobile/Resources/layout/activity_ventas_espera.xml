<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#B22222"
        android:paddingLeft="8dp"
        android:paddingRight="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnVolverEspera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:padding="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ventas en espera"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="4dp" />

        <TextView
            android:id="@+id/lblConteoEspera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="13sp"
            android:textColor="#FFCCCC" />
    </LinearLayout>

    <ListView
        android:id="@+id/lstVentasEspera"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#F0F0F0"
        android:dividerHeight="1dp"
        android:background="#FFFFFF"
        android:layout_margin="8dp"
        android:elevation="2dp" />

    <TextView
        android:id="@+id/lblSinEspera"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No hay ventas en espera"
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
