<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#B22222"
        android:paddingLeft="8dp"
        android:paddingRight="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnVolverResumen"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:padding="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ventas del día"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="4dp" />
    </LinearLayout>

    <!-- Tarjetas resumen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Total ventas -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:layout_marginRight="4dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/lblResumenTotalVentas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#B22222" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VENTAS"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- Total recaudado -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="2"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:layout_marginLeft="4dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/lblResumenTotalRecaudado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 CUP"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECAUDADO"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Desglose efectivo / transferencia -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginRight="4dp"
            android:elevation="1dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_cash"
                android:scaleType="fitCenter"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/lblResumenEfectivo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0.00 CUP"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginLeft="4dp"
            android:elevation="1dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_transfer"
                android:scaleType="fitCenter"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/lblResumenTransferencia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0.00 CUP"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333" />
        </LinearLayout>
    </LinearLayout>

    <!-- Lista de ventas -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DETALLE DE VENTAS"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#AAAAAA"
        android:letterSpacing="0.12"
        android:paddingLeft="16dp"
        android:paddingBottom="6dp" />

    <ListView
        android:id="@+id/lstVentasDia"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#F0F0F0"
        android:dividerHeight="1dp"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:elevation="2dp" />

    <TextView
        android:id="@+id/lblResumenVacio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Sin ventas registradas hoy"
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
