<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#B22222"
        android:paddingLeft="8dp"
        android:paddingRight="12dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnVolverCobro"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:padding="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginLeft="4dp">

            <TextView
                android:id="@+id/lblTotalCobro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total: 0.00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/lblPendienteCobro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente: 0.00"
                android:textSize="12sp"
                android:textColor="#FFCCCC" />
        </LinearLayout>

        <Button
            android:id="@+id/btnArchivarEspera"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Archivar"
            android:textSize="12sp"
            android:textColor="#B22222"
            android:background="#FFFFFF"
            android:paddingLeft="10dp"
            android:paddingRight="10dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Sección: pagos ya registrados -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PAGOS REGISTRADOS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.12"
                android:paddingLeft="8dp"
                android:paddingBottom="6dp"
                android:paddingTop="4dp" />

            <LinearLayout
                android:id="@+id/contenedorPagosRegistrados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/lblSinPagos"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Sin pagos registrados aún"
                    android:textSize="13sp"
                    android:textColor="#CCCCCC"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Sección: agregar pago -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AGREGAR PAGO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.12"
                android:paddingLeft="8dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="8dp">

                <!-- Selector método -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Método"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:id="@+id/tarjetaEfectivo"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="10dp"
                        android:layout_marginRight="6dp"
                        android:background="@drawable/btn_outline_firebrick">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_cash"
                            android:scaleType="fitCenter"
                            android:layout_marginRight="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Efectivo"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#B22222" />

                        <RadioButton
                            android:id="@+id/rbEfectivo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="#B22222"
                            android:checked="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tarjetaTransferencia"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="10dp"
                        android:background="@drawable/btn_outline_firebrick">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_transfer"
                            android:scaleType="fitCenter"
                            android:layout_marginRight="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Transferencia"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#B22222" />

                        <RadioButton
                            android:id="@+id/rbTransferencia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="#B22222" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Selector moneda -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Moneda"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerMoneda"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/search_field_bg"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_marginBottom="14dp" />

                <!-- Monto -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Monto"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/txtMontoPago"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="0.00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:inputType="numberDecimal"
                    android:background="@drawable/search_field_bg"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:layout_marginBottom="10dp" />

                <!-- Equivalente en moneda base (visible solo si moneda != base) -->
                <TextView
                    android:id="@+id/lblEquivalenteBase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <!-- Campos adicionales para transferencia -->
                <LinearLayout
                    android:id="@+id/panelTransferencia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nro. de transacción *"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/txtNroTransferencia"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Número de transacción"
                        android:textSize="14sp"
                        android:inputType="text"
                        android:background="@drawable/search_field_bg"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Teléfono remitente (opcional)"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/txtTelefonoRemitente"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="+53 5XXXXXXX"
                        android:textSize="14sp"
                        android:inputType="phone"
                        android:background="@drawable/search_field_bg"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Si la transferencia aún no llegó, use 'Archivar' para atender al próximo cliente y completar este pago después."
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginBottom="12dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnAgregarPago"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="+ Agregar este pago"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#B22222"
                    android:background="@drawable/btn_outline_firebrick" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Confirmar (fijo abajo) -->
    <Button
        android:id="@+id/btnConfirmarCobro"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirmar cobro"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_firebrick"
        android:layout_margin="16dp"
        android:enabled="false"
        android:alpha="0.5" />

</LinearLayout>
