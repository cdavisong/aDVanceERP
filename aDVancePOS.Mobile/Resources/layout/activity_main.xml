<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

	<!-- ══════════════════════════════════════
         TOOLBAR / HEADER
         ══════════════════════════════════════ -->
	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:elevation="4dp">

		<!-- Marca -->
		<LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false">

			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="aDVance"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:includeFontPadding="false" />

			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="POS"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#B22222"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginLeft="6dp"
                android:includeFontPadding="false" />
		</LinearLayout>

		<!-- Badge ventas: label a la izquierda, círculo a la derecha -->
		<LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginRight="12dp">

			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VENTAS"
                android:textSize="8sp"
                android:textColor="#AAAAAA"
                android:layout_marginRight="4dp" />

			<!-- Círculo clickeable con contador de ventas del día -->
			<TextView
                android:id="@+id/lblVentasBadge"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#B22222"
                android:gravity="center"
                android:background="@drawable/circle_outline"
                android:clickable="true"
                android:focusable="true" />
		</LinearLayout>

		<!-- Botón Configuración -->
		<ImageButton
            android:id="@+id/btnConfiguracion"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:contentDescription="Configuración" />
	</LinearLayout>

	<!-- ══════════════════════════════════════
         BUSCADOR
         ══════════════════════════════════════ -->
	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginTop="1dp"
        android:elevation="2dp">

		<LinearLayout
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/search_field_bg"
            android:paddingLeft="12dp"
            android:paddingRight="8dp">

			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="16sp"
                android:layout_marginRight="6dp" />

			<EditText
                android:id="@+id/txtBuscar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Buscar producto, código..."
                android:textSize="14sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

			<Button
                android:id="@+id/btnLimpiarBusqueda"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="✕"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:visibility="gone" />
		</LinearLayout>

		<!-- Botón escáner de código de barras -->
		<ImageButton
            android:id="@+id/btnEscanear"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_scan"
            android:background="@drawable/btn_outline_firebrick"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:layout_marginLeft="8dp"
            android:contentDescription="Escáner" />

		<LinearLayout
            android:id="@+id/btnImportar"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/btn_outline_firebrick"
            android:paddingLeft="10dp"
            android:paddingRight="12dp"
            android:layout_marginLeft="8dp">

			<ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_catalog"
                android:scaleType="fitCenter"
                android:layout_marginRight="5dp" />

			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catálogo"
                android:textSize="13sp"
                android:textColor="#B22222"
                android:textStyle="bold" />
		</LinearLayout>
	</LinearLayout>

	<!-- ══════════════════════════════════════
         CONTENIDO PRINCIPAL
         ══════════════════════════════════════ -->
	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

		<!-- ─── SECCIÓN PRODUCTOS ─── -->
		<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:layout_marginTop="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:elevation="2dp">

			<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="#FAFAFA">

				<TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PRODUCTOS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#999999"
                    android:letterSpacing="0.1" />

				<TextView
                    android:id="@+id/lblConteoProductos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 resultados"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA" />
			</LinearLayout>

			<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

			<ListView
                android:id="@+id/lstProductos"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#F0F0F0"
                android:dividerHeight="1dp"
                android:scrollbars="vertical" />

			<TextView
                android:id="@+id/lblProductosVacio"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="Sin productos. Usa '＋ Catálogo' para importar."
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:visibility="gone" />
		</LinearLayout>

		<!-- ─── SECCIÓN CARRITO ─── -->
		<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:layout_marginTop="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="8dp"
            android:elevation="2dp">

			<!-- Cabecera carrito -->
			<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="#FAFAFA">

				<ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_cart"
                    android:scaleType="fitCenter"
                    android:layout_marginRight="6dp" />

				<TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CARRITO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#999999"
                    android:letterSpacing="0.1" />

				<Button
                    android:id="@+id/btnVaciarCarrito"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Vaciar"
                    android:textSize="11sp"
                    android:textColor="#B22222"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />
			</LinearLayout>

			<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

			<ListView
                android:id="@+id/lstCarrito"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#F0F0F0"
                android:dividerHeight="1dp" />

			<TextView
                android:id="@+id/lblCarritoVacio"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="El carrito está vacío"
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:visibility="gone" />

			<!-- Divisor total -->
			<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

			<!-- Fila de total -->
			<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="#FAFAFA">

				<TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:letterSpacing="0.1" />

				<View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

				<TextView
                    android:id="@+id/lblTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
			</LinearLayout>

			<!-- Divisor pagos -->
			<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

			<!-- FIX #4: Sección de pagos con título + habilitación condicional
                 El LinearLayout completo se habilita/deshabilita desde código.
                 Cuando está deshabilitado, alpha=0.35 da la apariencia de inactivo. -->
			<LinearLayout
                android:id="@+id/seccionPagos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF">

				<!-- Título de sección pagos -->
				<TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MÉTODO DE PAGO"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#BBBBBB"
                    android:letterSpacing="0.15"
                    android:gravity="center"
                    android:paddingTop="6dp"
                    android:paddingBottom="2dp" />

				<!-- Botón único de cobro — abre diálogo con Efectivo / Transferencia / Mixto -->
				<LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

					<LinearLayout
                        android:id="@+id/btnCobrar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/btn_firebrick">

						<ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_pay"
                            android:scaleType="fitCenter"
                            android:layout_marginRight="8dp" />

						<TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cobrar"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
					</LinearLayout>
				</LinearLayout>
			</LinearLayout>
			<!-- fin seccionPagos -->

		</LinearLayout>
		<!-- fin carrito -->

	</LinearLayout>

</LinearLayout>