<?xml version="1.0" encoding="utf-8"?>
<!--
    PANTALLA PRINCIPAL POS - activity_main.xml

    Estructura:
    ┌──────────────────────────────────────┐
    │  TOOLBAR  (aDVance ERP + badge)      │
    ├──────────────────────────────────────┤
    │  BUSCADOR + botón limpiar            │
    ├────────────────┬─────────────────────┤
    │  LISTA         │  CARRITO            │
    │  PRODUCTOS     │  (items)            │
    │  (izq ~55%)    │  ─────────────────  │
    │                │  Total + botones    │
    └────────────────┴─────────────────────┘
    En pantallas pequeñas (sw < 600dp) la orientación se vuelve vertical.
    Para eso crea res/layout-sw600dp/activity_main.xml con orientation horizontal.
    Este archivo usa orientación vertical (móvil estándar).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

	<!-- ══════════════════════════════════════
         TOOLBAR / HEADER
         ══════════════════════════════════════ -->
	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:elevation="4dp">

		<!-- Marca -->
		<LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="aDV"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#222222" />

			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ance"
                android:textSize="20sp"
                android:textColor="#222222" />

			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ERP"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#B22222"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="2dp"
                android:layout_marginLeft="4dp" />
		</LinearLayout>

		<!-- Badge contador carrito -->
		<TextView
            android:id="@+id/lblCarritoBadge"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#B22222"
            android:gravity="center"
            android:background="@drawable/circle_outline"
            android:layout_marginRight="8dp" />

		<!-- Botón exportar / menú (ícono ≡) -->
		<Button
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="⋮"
            android:textSize="22sp"
            android:textColor="#555555"
            android:background="@android:color/transparent"
            android:padding="0dp" />
	</LinearLayout>

	<!-- ══════════════════════════════════════
         BUSCADOR
         ══════════════════════════════════════ -->
	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginTop="1dp"
        android:elevation="2dp">

		<!-- Campo de búsqueda -->
		<LinearLayout
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/search_field_bg"
            android:paddingLeft="12dp"
            android:paddingRight="8dp">

			<!-- Ícono lupa (unicode) -->
			<TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="16sp"
                android:layout_marginRight="6dp" />

			<EditText
                android:id="@+id/txtBuscar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Buscar producto, código..."
                android:textSize="14sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

			<!-- Borrar búsqueda -->
			<Button
                android:id="@+id/btnLimpiarBusqueda"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="✕"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:visibility="gone" />
		</LinearLayout>

		<!-- Botón importar catálogo -->
		<Button
            android:id="@+id/btnImportar"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="＋ Catálogo"
            android:textSize="13sp"
            android:textColor="#B22222"
            android:background="@drawable/btn_outline_firebrick"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginLeft="8dp" />
	</LinearLayout>

	<!-- ══════════════════════════════════════
         CONTENIDO PRINCIPAL
         (Lista productos arriba, carrito abajo)
         ══════════════════════════════════════ -->
	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

		<!-- ─── SECCIÓN PRODUCTOS ─── -->
		<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:layout_marginTop="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:elevation="2dp">

			<!-- Cabecera sección -->
			<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="#FAFAFA">

				<TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PRODUCTOS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#999999"
                    android:letterSpacing="0.1" />

				<TextView
                    android:id="@+id/lblConteoProductos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 resultados"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA" />
			</LinearLayout>

			<!-- Divisor -->
			<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

			<!-- Lista de productos -->
			<ListView
                android:id="@+id/lstProductos"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#F0F0F0"
                android:dividerHeight="1dp"
                android:scrollbars="vertical" />

			<!-- Estado vacío -->
			<TextView
                android:id="@+id/lblProductosVacio"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="Sin productos. Usa '＋ Catálogo' para importar."
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:visibility="gone" />
		</LinearLayout>

		<!-- ─── SECCIÓN CARRITO ─── -->
		<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:layout_marginTop="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="8dp"
            android:elevation="2dp">

			<!-- Cabecera carrito -->
			<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="#FAFAFA">

				<TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🛒  CARRITO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#999999"
                    android:letterSpacing="0.1" />

				<!-- Vaciar carrito -->
				<Button
                    android:id="@+id/btnVaciarCarrito"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="Vaciar"
                    android:textSize="11sp"
                    android:textColor="#B22222"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />
			</LinearLayout>

			<!-- Divisor -->
			<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

			<!-- Items del carrito -->
			<ListView
                android:id="@+id/lstCarrito"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#F0F0F0"
                android:dividerHeight="1dp" />

			<!-- Carrito vacío -->
			<TextView
                android:id="@+id/lblCarritoVacio"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="El carrito está vacío"
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:visibility="gone" />

			<!-- Divisor total -->
			<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

			<!-- Fila de total -->
			<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="#FAFAFA">

				<TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:letterSpacing="0.1" />

				<View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

				<TextView
                    android:id="@+id/lblTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
			</LinearLayout>

			<!-- Divisor botones -->
			<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

			<!-- Botones de pago -->
			<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical"
                android:background="#FFFFFF">

				<!-- Efectivo -->
				<Button
                    android:id="@+id/btnPagarEfectivo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="💵  Efectivo"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_firebrick"
                    android:layout_marginRight="6dp" />

				<!-- Transferencia -->
				<Button
                    android:id="@+id/btnPagarTransferencia"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="📲  Transferencia"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#B22222"
                    android:background="@drawable/btn_peachpuff"
                    android:layout_marginLeft="6dp" />
			</LinearLayout>

		</LinearLayout>
		<!-- fin carrito -->

	</LinearLayout>
	<!-- fin contenido principal -->

</LinearLayout>